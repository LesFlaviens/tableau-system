<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Empire OS - Unité de Contrôle HACCP</title>
    <style>
        :root { --bg: #050505; --text: #fff; --panel: #111; --accent: #00e676; --gold: #ffb300; --alert: #ff1744; --info: #2979ff; }
        body { font-family: 'Inter', sans-serif; background: var(--bg); color: var(--text); margin: 0; padding: 0; overflow: hidden; }
        
        header { background: #000; border-bottom: 2px solid #333; padding: 15px 25px; display: flex; justify-content: space-between; align-items: center; }
        .logo { font-weight: 900; letter-spacing: 3px; font-size: 1.2rem; color: var(--accent); }
        
        /* NAVIGATION DES 4 FENÊTRES */
        .haccp-nav { display: flex; background: #0a0a0a; border-bottom: 1px solid #333; }
        .nav-btn { flex: 1; padding: 20px; border: none; background: transparent; color: #888; font-weight: 900; cursor: pointer; text-transform: uppercase; transition: 0.3s; border-right: 1px solid #222; }
        .nav-btn.active { color: #fff; background: #111; }
        .nav-btn:hover { background: #111; }
        #btn-cuisine.active { border-bottom: 4px solid var(--gold); }
        #btn-bar.active { border-bottom: 4px solid var(--info); }
        #btn-service.active { border-bottom: 4px solid var(--accent); }
        #btn-direction.active { border-bottom: 4px solid var(--alert); }

        .workspace { height: calc(100vh - 120px); overflow-y: auto; padding: 30px; box-sizing: border-box; display: none; }
        .workspace.active { display: block; }

        /* MODULES */
        .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(350px, 1fr)); gap: 20px; }
        .card { background: var(--panel); border: 1px solid #333; border-radius: 8px; padding: 20px; }
        .card-title { font-size: 0.8rem; font-weight: 900; text-transform: uppercase; color: var(--gold); margin-bottom: 15px; display: flex; justify-content: space-between; }
        
        .input-group { margin-bottom: 15px; }
        label { display: block; font-size: 0.7rem; color: #888; margin-bottom: 5px; text-transform: uppercase; }
        input, select { width: 100%; background: #000; border: 1px solid #444; color: #fff; padding: 12px; border-radius: 4px; font-weight: bold; box-sizing: border-box; }
        
        .btn-submit { width: 100%; padding: 15px; border: none; border-radius: 4px; font-weight: 900; cursor: pointer; text-transform: uppercase; margin-top: 10px; }
        .btn-cuisine { background: var(--gold); color: #000; }
        .btn-bar { background: var(--info); color: #fff; }
        .btn-service { background: var(--accent); color: #000; }
        
        /* LOGS */
        .log-table { width: 100%; border-collapse: collapse; margin-top: 20px; font-size: 0.8rem; }
        .log-table th { text-align: left; color: #666; padding: 10px; border-bottom: 1px solid #333; }
        .log-table td { padding: 10px; border-bottom: 1px solid #222; }
        .status-ok { color: var(--accent); font-weight: bold; }

        /* DIRECTION / AUDIT */
        .audit-header { background: var(--alert); color: #fff; padding: 20px; border-radius: 8px; margin-bottom: 30px; display: flex; justify-content: space-between; align-items: center; }
        .btn-export { background: #fff; color: #000; padding: 10px 20px; border-radius: 4px; font-weight: 900; border: none; cursor: pointer; }
    </style>
</head>
<body>

    <header>
        <div class="logo">EMPIRE HACCP UNIT</div>
        <div style="font-size: 0.8rem; font-weight: bold;" id="live-clock">--:--:--</div>
    </header>

    <nav class="haccp-nav">
        <button id="btn-cuisine" class="nav-btn active" onclick="switchTab('cuisine')">👨‍🍳 Cuisine</button>
        <button id="btn-bar" class="nav-btn" onclick="switchTab('bar')">🍸 Bar</button>
        <button id="btn-service" class="nav-btn" onclick="switchTab('service')">🍽️ Service</button>
        <button id="btn-direction" class="nav-btn" onclick="switchTab('direction')">⚖️ Direction</button>
    </nav>

    <section id="view-cuisine" class="workspace active">
        <div class="grid">
            <div class="card">
                <div class="card-title">🌡️ RELEVÉ DES TEMPÉRATURES</div>
                <div class="input-group">
                    <label>Équipement</label>
                    <select id="c-eq">
                        <option>CF Positive Viandes</option>
                        <option>CF Positive Légumes</option>
                        <option>Congélateur -18°C</option>
                        <option>Cellule de refroidissement</option>
                    </select>
                </div>
                <div class="input-group">
                    <label>Température constatée (°C)</label>
                    <input type="number" id="c-temp" step="0.1" placeholder="Ex: 3.4">
                </div>
                <button class="btn-submit btn-cuisine" onclick="saveLog('Cuisine', 'Température')">Valider le relevé</button>
            </div>
            <div class="card">
                <div class="card-title">🧹 PLAN DE NETTOYAGE</div>
                <div class="input-group">
                    <label>Zone nettoyée</label>
                    <select id="c-clean">
                        <option>Plans de travail & Inox</option>
                        <option>Sols & Siphons</option>
                        <option>Hottes & Filtres</option>
                        <option>Plonge & Lave-vaisselle</option>
                    </select>
                </div>
                <button class="btn-submit btn-cuisine" onclick="saveLog('Cuisine', 'Nettoyage')">Enregistrer Nettoyage</button>
            </div>
        </div>
    </section>

    <section id="view-bar" class="workspace">
        <div class="grid">
            <div class="card">
                <div class="card-title">🌡️ TEMPÉRATURES BAR</div>
                <div class="input-group">
                    <label>Frigo</label>
                    <select id="b-eq">
                        <option>Arrière-Bar Boissons</option>
                        <option>Frigo Lait / Fruits</option>
                        <option>Cave à vins</option>
                    </select>
                </div>
                <input type="number" id="b-temp" step="0.1" placeholder="Température">
                <button class="btn-submit btn-bar" onclick="saveLog('Bar', 'Température')">Valider</button>
            </div>
            <div class="card">
                <div class="card-title">❄️ HYGIÈNE GLAÇONS</div>
                <p style="font-size: 0.7rem; color: #888;">Nettoyage hebdomadaire de la machine et désinfection de la pelle.</p>
                <button class="btn-submit btn-bar" onclick="saveLog('Bar', 'Nettoyage Glaçons')">Machine Nettoyée / Conforme</button>
            </div>
        </div>
    </section>

    <section id="view-service" class="workspace">
        <div class="grid">
            <div class="card">
                <div class="card-title">🚻 CONTRÔLE SANITAIRES</div>
                <div class="input-group">
                    <label>État des toilettes</label>
                    <select id="s-san">
                        <option>Toilettes Clients Hommes</option>
                        <option>Toilettes Clients Femmes</option>
                    </select>
                </div>
                <button class="btn-submit btn-service" onclick="saveLog('Service', 'Sanitaires OK')">Passage effectué / Propre</button>
            </div>
            <div class="card">
                <div class="card-title">🧺 TEXTILES & SALLE</div>
                <button class="btn-submit btn-service" onclick="saveLog('Service', 'Nappage/Tables OK')">Tables & Menus désinfectés</button>
            </div>
        </div>
    </section>

    <section id="view-direction" class="workspace">
        <div class="audit-header">
            <div>
                <h2 style="margin:0;">MODE INSPECTION HYGIÈNE</h2>
                <small>Registre légal des contrôles effectués 24h/24</small>
            </div>
            <button class="btn-export" onclick="exportData()">📥 EXPORTER REGISTRE (CSV)</button>
        </div>
        
        <div class="card">
            <div class="card-title">HISTORIQUE GLOBAL DES ACTIONS</div>
            <table class="log-table" id="audit-table">
                <thead>
                    <tr>
                        <th>Date & Heure</th>
                        <th>Section</th>
                        <th>Type d'action</th>
                        <th>Détail / Valeur</th>
                        <th>Statut</th>
                    </tr>
                </thead>
                <tbody id="audit-logs"></tbody>
            </table>
        </div>
    </section>

    <script>
        // Moteur de Télétransmission H24
        async function syncHaccp(log) {
            const payload = { 
                tableId: 'HACCP_LOG_' + Date.now(), 
                order: { status: 'system', haccpData: log } 
            };
            await fetch('/update-order', { 
                method: 'POST', 
                headers: { 'Content-Type': 'application/json' }, 
                body: JSON.stringify(payload) 
            });
        }

        function switchTab(tab) {
            document.querySelectorAll('.workspace').forEach(w => w.classList.remove('active'));
            document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
            document.getElementById('view-' + tab).classList.add('active');
            document.getElementById('btn-' + tab).classList.add('active');
            if(tab === 'direction') renderAudit();
        }

        function saveLog(section, type) {
            let detail = "";
            if(section === 'Cuisine' && type === 'Température') detail = document.getElementById('c-eq').value + ": " + document.getElementById('c-temp').value + "°C";
            else if(section === 'Cuisine' && type === 'Nettoyage') detail = document.getElementById('c-clean').value;
            else if(section === 'Bar' && type === 'Température') detail = document.getElementById('b-eq').value + ": " + document.getElementById('b-temp').value + "°C";
            else if(section === 'Bar') detail = "Action Bar validée";
            else detail = "Check-list Service validée";

            const log = {
                timestamp: new Date().toLocaleString('fr-FR'),
                section: section,
                type: type,
                detail: detail,
                status: "CONFORME"
            };

            let logs = JSON.parse(localStorage.getItem('empire_haccp_logs')) || [];
            logs.unshift(log);
            localStorage.setItem('empire_haccp_logs', JSON.stringify(logs));
            
            syncHaccp(log); // Envoi au serveur pour la Direction
            alert("✅ Enregistrement HACCP validé.");
        }

        function renderAudit() {
            const logs = JSON.parse(localStorage.getItem('empire_haccp_logs')) || [];
            const container = document.getElementById('audit-logs');
            container.innerHTML = logs.map(l => `
                <tr>
                    <td>${l.timestamp}</td>
                    <td><b>${l.section}</b></td>
                    <td>${l.type}</td>
                    <td>${l.detail}</td>
                    <td class="status-ok">${l.status}</td>
                </tr>
            `).join('');
        }

        function exportData() {
            const logs = JSON.parse(localStorage.getItem('empire_haccp_logs')) || [];
            let csv = "Date;Section;Type;Details;Statut\n";
            logs.forEach(l => {
                csv += `${l.timestamp};${l.section};${l.type};${l.detail};${l.status}\n`;
            });
            const blob = new Blob([csv], { type: 'text/csv' });
            const url = window.URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.setAttribute('hidden', '');
            a.setAttribute('href', url);
            a.setAttribute('download', 'REGISTRE_HACCP_EMPIRE.csv');
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
        }

        // Horloge temps réel
        setInterval(() => {
            document.getElementById('live-clock').innerText = new Date().toLocaleTimeString('fr-FR');
        }, 1000);
    </script>
</body>
</html>
