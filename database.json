<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>TEST CONNEXION EMPIRE</title>
    <style>
        body { background: #0f172a; color: white; font-family: sans-serif; text-align: center; padding: 50px; }
        .status { padding: 20px; border-radius: 10px; margin-bottom: 20px; font-weight: bold; }
        .online { background: #065f46; border: 2px solid #34d399; }
        .offline { background: #7f1d1d; border: 2px solid #f87171; }
        button { padding: 15px 30px; font-size: 1.2rem; cursor: pointer; background: #fbbf24; border: none; border-radius: 5px; font-weight: bold; }
    </style>
</head>
<body>
    <h1>TEST DE LIAISON BAR</h1>
    <div id="stat" class="status offline">DÉCONNECTÉ</div>
    <button onclick="testerSauvegarde()">🚀 TESTER L'ENREGISTREMENT</button>

    <script>
        async function verifier() {
            try {
                const r = await fetch('/get-current-state');
                if(r.ok) {
                    document.getElementById('stat').className = "status online";
                    document.getElementById('stat').innerText = "EN LIGNE : SERVEUR PRÊT";
                }
            } catch(e) {
                document.getElementById('stat').className = "status offline";
                document.getElementById('stat').innerText = "DÉCONNECTÉ : VÉRIFIE RENDER";
            }
        }

        async function testerSauvegarde() {
            const donneeTest = { test: "Succès", date: new Date().toLocaleTimeString() };
            try {
                const r = await fetch('/update-order', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({ tableId: 'MENU_MASTER_BAR', order: { data: donneeTest } })
                });
                if(r.ok) alert("✅ ENREGISTREMENT RÉUSSI ! La base de données a répondu.");
                else alert("❌ ÉCHEC : Le serveur refuse l'écriture.");
            } catch(e) {
                alert("❌ ERREUR RÉSEAU");
            }
        }

        setInterval(verifier, 3000);
        verifier();
    </script>
</body>
</html>
