<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Empire KDS - Cuisine</title>
    <style>
        :root { --bg: #050505; --accent: #00e676; --alert: #ff1744; --text: #fff; --panel: #111; --haccp: #00b0ff; --hr: #2979ff; --gold: #ffb300; --purple: #ea80fc; }
        body { font-family: 'Inter', sans-serif; background: var(--bg); color: var(--text); margin: 0; display: flex; height: 100vh; overflow: hidden; }
        
        #start-overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.95); z-index: 9999; display: flex; justify-content: center; align-items: center; flex-direction: column; }
        #start-overlay button { padding: 20px 40px; font-size: 1.5rem; font-weight: 900; background: var(--alert); color: #fff; border: none; border-radius: 8px; cursor: pointer; text-transform: uppercase; animation: pulse 2s infinite; }
        @keyframes pulse { 0% { transform: scale(1); } 50% { transform: scale(1.05); } 100% { transform: scale(1); } }

        #production-area { flex: 1; padding: 20px; overflow-y: auto; position: relative; width: 100%;}
        
        .header-container { display: flex; justify-content: space-between; align-items: center; border-bottom: 2px solid #333; padding-bottom: 10px; margin-bottom: 10px; }
        .header-title { color: var(--alert); text-transform: uppercase; letter-spacing: 2px; margin: 0; display: flex; align-items: center;}
        
        /* RADAR RÉSERVATIONS DYNAMIQUE */
        .radar-bar { background: #0a0a0a; border: 1px dashed #333; padding: 10px 20px; border-radius: 8px; display: flex; gap: 15px; align-items: center; margin-bottom: 20px; overflow-x: auto; }
        .radar-title { color: var(--purple); font-weight: 900; text-transform: uppercase; font-size: 0.9rem; white-space: nowrap; }
        .radar-total { border: 1px solid var(--purple); padding: 5px 12px; border-radius: 6px; color: var(--purple); font-weight: bold; }
        .radar-item { background: #111; border: 1px solid #333; padding: 5px 12px; border-radius: 6px; color: #ccc; font-weight: bold; white-space: nowrap; }

        .btn-top { background: #1a1a1a; font-weight: bold; border-radius: 4px; padding: 8px 15px; cursor: pointer; text-transform: uppercase; transition: 0.2s; font-size: 0.85rem; color:#fff; border: 1px solid transparent;}
        .btn-top:hover { filter: brightness(1.3); }

        .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 20px; }
        .ticket { background: var(--panel); border: 1px solid #333; border-top: 8px solid var(--alert); border-radius: 8px; box-shadow: 0 10px 30px rgba(0,0,0,0.5); display: flex; flex-direction: column; }
        .ticket-header { background: #1a1a1a; padding: 15px; font-size: 1.3rem; font-weight: 900; border-bottom: 1px solid #333; display: flex; justify-content: space-between; align-items: center;}
        .ticket-covers { background: #333; padding: 4px 10px; border-radius: 6px; font-size: 1rem; color: #fff; }
        .ticket-body { padding: 15px; flex: 1; }
        
        .course-section { margin-bottom: 15px; background: #0a0a0a; border-radius: 6px; overflow: hidden; border: 1px solid #222; }
        .course-title { background: #222; padding: 8px 12px; font-size: 0.8rem; color: #aaa; text-transform: uppercase; font-weight: bold; letter-spacing: 1px; }
        .course-items { padding: 10px 12px; list-style: none; margin: 0; font-size: 1.1rem; font-weight: bold; }
        .course-items li { margin-bottom: 8px; display: flex; justify-content: space-between; }
        
        .btn-send { width: 100%; padding: 15px; background: var(--accent); border: none; color: #000; font-weight: 900; font-size: 1rem; cursor: pointer; text-transform: uppercase; transition: 0.1s; }

        /* TIROIRS ET MODALS */
        .drawer { position: absolute; left: 0; top: 0; width: 450px; height: 100%; background: #0a0a0a; border-right: 2px solid #333; padding: 25px; z-index: 8000; box-sizing: border-box; overflow-y: auto; transform: translateX(-100%); transition: transform 0.3s cubic-bezier(0.4, 0.0, 0.2, 1); box-shadow: 15px 0 50px rgba(0,0,0,0.9); }
        .drawer.open { transform: translateX(0); }
        #gestion-drawer, #cmd-drawer { width: 100vw; max-width: 100%; z-index: 8500; border-right: none; padding: 40px; }
        .btn-close-drawer { position: absolute; top: 20px; right: 20px; background: transparent; border: none; color: #aaa; font-size: 1.5rem; font-weight: bold; cursor: pointer; }
        .input-field { width: 100%; background: #000; border: 1px solid #444; color: #fff; padding: 12px; border-radius: 6px; margin-bottom: 15px; box-sizing: border-box;}
        .recipe-row { background: #161616; border: 1px solid #333; margin-bottom: 8px; border-radius: 6px; }
        .recipe-btn { background: transparent; border: none; color: #fff; padding: 15px; font-size: 1.1rem; cursor: pointer; font-weight: bold; text-align: left; width: 100%;}
        .mega-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 30px; height: calc(100vh - 180px); overflow-y: auto; }
    </style>
</head>
<body>

    <div id="start-overlay">
        <h1 style="margin-bottom: 30px;">KITCHEN DISPLAY SYSTEM</h1>
        <button onclick="initSystem()">DÉMARRER LE SERVICE (ACTIVER SON)</button>
    </div>

    <div id="recipe-modal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.95); z-index:10000; display:none; justify-content:center; align-items:center; padding:40px;">
        <div style="background:#1a1a1a; width:100%; max-width:800px; height:100%; border-radius:12px; padding:40px; border:1px solid #333; position:relative; overflow-y:auto;">
            <button onclick="closeRecipeModal()" style="position:absolute; top:20px; right:20px; background:var(--alert); color:#fff; border:none; padding:10px 20px; border-radius:6px; cursor:pointer;">FERMER</button>
            <h2 id="modal-recipe-title" style="color:var(--accent); font-size:2.5rem; border-bottom:2px solid #333; padding-bottom:15px;">Titre</h2>
            <pre id="modal-recipe-content" style="white-space: pre-wrap; font-family: 'Inter', sans-serif; font-size: 1.2rem; color: #ccc; margin-top:20px;">Contenu</pre>
        </div>
    </div>

    <div id="production-area">
        <div class="header-container">
            <h2 class="header-title">🔥 GESTION DE LA CUISINE <span id="pending-count" style="color:#fff; margin-left: 15px; font-size: 1rem; text-transform: none;">0 plats à envoyer</span></h2>
            <div style="display: flex; gap: 10px;">
                <button class="btn-top" style="border-color:#888; color:#888;" onclick="openDrawer('history-drawer')">✔️ HISTORIQUE</button>
                <button class="btn-top" style="border-color:var(--hr); color:var(--hr);" onclick="openStaffPlanning()">📅 PLANNING</button>
                <button class="btn-top" style="border-color:#ea80fc; color:#ea80fc;" onclick="openResDrawer()">📅 RÉSA</button>
                <button class="btn-top" style="border-color:var(--gold); color:var(--gold);" onclick="openCommandesDrawer()">🛒 COURSES</button>
                <button class="btn-top" style="background: #222; border-color:#fff; color:#fff;" onclick="openGestionDrawer()">⚙️ HACCP</button>
            </div>
        </div>

        <div class="radar-bar" id="radar-bar">
            <div class="radar-title">📅 RADAR SERVICE :</div>
            <div id="radar-content" style="display:flex; gap:10px;"></div>
        </div>
        
        <div class="grid" id="pending-container"></div>

        <div id="history-drawer" class="drawer"><button class="btn-close-drawer" onclick="closeDrawer('history-drawer')">✕</button><h2 style="margin-top:30px; color:#888; text-transform:uppercase;">✔️ HISTORIQUE</h2><div id="history-container"></div></div>
        <div id="staff-drawer" class="drawer"><button class="btn-close-drawer" onclick="closeDrawer('staff-drawer')">✕</button><h2 style="margin-top:30px; color:var(--hr); text-transform:uppercase;">📅 PLANNING CUISINE</h2><div id="staff-planning-container"></div></div>
        <div id="res-drawer" class="drawer"><button class="btn-close-drawer" onclick="closeDrawer('res-drawer')">✕</button><h2 style="margin-top:30px; color:#ea80fc; text-transform:uppercase;">📅 RÉSERVATIONS</h2><div id="res-list-container"></div></div>
        <div id="cmd-drawer" class="drawer"><button class="btn-close-drawer" onclick="closeDrawer('cmd-drawer')">✕</button><h2 style="color:var(--gold);">🛒 GESTION DES ACHATS</h2><div id="cmd-list-container"></div></div>
        <div id="gestion-drawer" class="drawer"><button class="btn-close-drawer" onclick="closeGestionDrawer()">✕</button><h2 style="color:#fff;">⚙️ HACCP & DATA</h2><div id="gestion-content"></div></div>
    </div>

    <script>
        let audioCtx; let activeOrders = []; let previousTicketCount = 0;

        function initSystem() {
            try { audioCtx = new (window.AudioContext || window.webkitAudioContext)(); } catch(e){}
            document.getElementById('start-overlay').style.display = 'none';
            renderKDS(); renderRadar();
        }

        function playSound(type) {
            if (!audioCtx) return;
            const osc = audioCtx.createOscillator(); const gain = audioCtx.createGain();
            osc.connect(gain); gain.connect(audioCtx.destination);
            const now = audioCtx.currentTime;
            if (type === 'new') { 
                osc.frequency.setValueAtTime(880, now); gain.gain.exponentialRampToValueAtTime(0.01, now + 0.5);
                osc.start(now); osc.stop(now + 0.5);
            }
        }

        // --- ECOUTE DES COMMANDES ET RÉSERVATIONS (CLOUD LOCAL) ---
        window.addEventListener('storage', function(e) {
            if (e.key === 'empire_kds_queue') renderKDS();
            if (e.key === 'empire_reservations') renderRadar();
        });

        function getTodayString() { const d = new Date(); return `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`; }

        // --- MOTEUR DU RADAR ---
        function renderRadar() {
            const today = getTodayString();
            const resas = JSON.parse(localStorage.getItem('empire_reservations')) || {};
            const dayResas = resas[today] || [];
            const container = document.getElementById('radar-content');
            if (dayResas.length === 0) { container.innerHTML = '<div style="color:#555;">Aucune réservation.</div>'; return; }
            let total = 0; let compo = {};
            dayResas.forEach(r => { total += parseInt(r.pax); compo[r.pax] = (compo[r.pax] || 0) + 1; });
            let html = `<div class="radar-total"><b>${total}</b> Couverts</div>`;
            Object.keys(compo).sort().forEach(p => { html += `<div class="radar-item"><b>${compo[p]}x</b> Table de ${p}</div>`; });
            container.innerHTML = html;
        }

        // --- MOTEUR KDS (BONS DE CUISINE) ---
        function renderKDS() {
            const queue = JSON.parse(localStorage.getItem('empire_kds_queue')) || [];
            const container = document.getElementById('pending-container');
            container.innerHTML = '';
            // Ne garder que la nourriture
            const orders = queue.filter(o => o.ticket.entrees.length > 0 || o.ticket.plats.length > 0 || o.ticket.desserts.length > 0);
            
            document.getElementById('pending-count').textContent = `${orders.length} bons en cuisine`;
            if (orders.length > previousTicketCount) playSound('new');
            previousTicketCount = orders.length;

            orders.forEach(order => {
                const ticket = document.createElement('div'); ticket.className = 'ticket';
                let body = '';
                const addSection = (title, items) => {
                    if (items.length === 0) return '';
                    const counts = {}; items.forEach(i => counts[i.name] = (counts[i.name] || 0) + 1);
                    return `<div class="course-section"><div class="course-title">${title}</div><ul class="course-items">${Object.entries(counts).map(([n, q]) => `<li><span>${q}x</span> ${n}</li>`).join('')}</ul></div>`;
                };
                body += addSection('1. Entrées', order.ticket.entrees);
                body += addSection('2. Plats', order.ticket.plats);
                body += addSection('3. Desserts', order.ticket.desserts);

                ticket.innerHTML = `
                    <div class="ticket-header"><span>${order.table}</span><span style="color:#666; font-size:0.9rem;">${order.time}</span></div>
                    <div class="ticket-body">${body}</div>
                    <button class="btn-send" onclick="finishOrder('${order.id}')">ENVOYER ✓</button>
                `;
                container.appendChild(ticket);
            });
        }

        function finishOrder(id) {
            let queue = JSON.parse(localStorage.getItem('empire_kds_queue')) || [];
            const idx = queue.findIndex(o => o.id === id);
            if (idx > -1) {
                // Archive pour stats
                const today = getTodayString();
                let stats = JSON.parse(localStorage.getItem('kds_archives_10ans')) || {};
                if (!stats[today]) stats[today] = {};
                [...queue[idx].ticket.entrees, ...queue[idx].ticket.plats, ...queue[idx].ticket.desserts].forEach(i => stats[today][i.name] = (stats[today][i.name] || 0) + 1);
                localStorage.setItem('kds_archives_10ans', JSON.stringify(stats));

                // On vide la partie cuisine
                queue[idx].ticket.entrees = []; queue[idx].ticket.plats = []; queue[idx].ticket.desserts = [];
                // Si bar vide aussi, on supprime le bon
                if (queue[idx].ticket.boissons.length === 0) queue.splice(idx, 1);
                localStorage.setItem('empire_kds_queue', JSON.stringify(queue));
                renderKDS();
            }
        }

        // --- STYLES DES TIROIRS ---
        function openDrawer(id) { document.getElementById(id).classList.add('open'); if(id==='res-drawer') renderResDrawer(); }
        function closeDrawer(id) { document.getElementById(id).classList.remove('open'); }
        function openResDrawer() { openDrawer('res-drawer'); }
        function renderResDrawer() {
            const today = getTodayString();
            const resas = (JSON.parse(localStorage.getItem('empire_reservations')) || {})[today] || [];
            document.getElementById('res-list-container').innerHTML = resas.map(r => `<div class="res-card"><b>${r.name}</b> - ${r.time}<br>Table ${r.table} (${r.pax}p)</div>`).join('') || 'Vide';
        }
        
        // Initialisation par défaut
        renderKDS(); renderRadar();
    </script>
</body>
</html>
