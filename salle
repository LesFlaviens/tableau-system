<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Empire OS - Terminal Salle</title>
    <style>
        :root { --bg: #050505; --accent: #00e676; --alert: #ff1744; --text: #fff; --panel: #111; --blue: #00b0ff; --warning: #ffb300; }
        body { font-family: 'Inter', sans-serif; background: var(--bg); color: var(--text); margin: 0; display: flex; flex-direction: column; height: 100vh; overflow: hidden; }
        header { border-bottom: 2px solid #222; padding: 15px; background: #0a0a0a; display: flex; justify-content: space-between; align-items: center; z-index: 1000; }
        .main-workspace { display: flex; flex: 1; position: relative; overflow: hidden; }
        .floor-plan { flex: 1; position: relative; background: #050505; z-index: 10; }
        
        /* TABLES : PRIORITÉ MAXIMALE AU CLIC */
        .table-obj { 
            position: absolute; background: #1a1a1a; border: 3px solid #444; color: #fff; 
            display: flex; justify-content: center; align-items: center; font-weight: 900; 
            border-radius: 12px; cursor: pointer; pointer-events: auto; z-index: 500;
            box-shadow: 0 10px 20px rgba(0,0,0,0.5); font-size: 1.5rem;
        }
        .table-obj.occupied { border-color: var(--alert); color: var(--alert); background: rgba(255,0,0,0.1); }

        .drawer-caisse { 
            position: absolute; top: 0; right: 0; width: 100%; max-width: 500px; height: 100%; 
            background: #0d0d0d; border-left: 3px solid #333; padding: 25px; z-index: 2000; 
            transform: translateX(100%); transition: 0.3s cubic-bezier(0.4, 0, 0.2, 1); display: flex; flex-direction: column; box-sizing: border-box;
        }
        .drawer-caisse.open { transform: translateX(0); }
        .ticket-area { flex: 1; background: #000; border: 1px solid #222; margin-bottom: 15px; padding: 15px; overflow-y: auto; font-family: monospace; }
        .menu-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
        .btn-item { background: #1a1a1a; border: 1px solid #333; color: #fff; padding: 15px; border-radius: 8px; font-weight: bold; }
        .btn-send { background: var(--accent); color: #000; padding: 20px; font-weight: 900; border: none; border-radius: 12px; font-size: 1.2rem; cursor: pointer; }
    </style>
</head>
<body>

    <header>
        <div style="color:var(--accent); font-weight:900; letter-spacing:2px;">EMPIRE TERMINAL v2.1</div>
        <button onclick="localStorage.clear(); location.reload();" style="background:var(--alert); color:#fff; border:none; padding:8px 15px; border-radius:6px; font-weight:bold; cursor:pointer;">RÉINITIALISER TOUT</button>
    </header>

    <div class="main-workspace">
        <div class="floor-plan" id="floor-plan"></div>

        <div id="caisse-drawer" class="drawer-caisse">
            <div style="display:flex; justify-content:space-between; margin-bottom:25px;">
                <h2 id="table-title" style="margin:0; color:var(--blue); font-size:2rem;">TABLE</h2>
                <button onclick="closeCaisse()" style="background:#333; border:none; color:#fff; width:50px; height:50px; border-radius:50%; font-size:1.5rem; cursor:pointer;">✕</button>
            </div>
            <div class="ticket-area" id="ticket-list"></div>
            <input type="text" id="order-observation" style="width:100%; background:#111; border:1px solid var(--warning); color:var(--warning); padding:15px; margin-bottom:15px; border-radius:8px; box-sizing:border-box;" placeholder="OBSERVATIONS...">
            <div class="menu-grid" id="menu-items"></div>
            <div id="total-val" style="font-size:2.5rem; font-weight:900; text-align:right; margin:20px 0; color:var(--accent);">0.00 €</div>
            <button class="btn-send" onclick="sendOrder()">🔥 ENVOYER EN PRODUCTION</button>
        </div>
    </div>

    <script>
        let currentTableId = null;
        let currentTicket = [];

        function closeCaisse() { document.getElementById('caisse-drawer').classList.remove('open'); }

        function loadFloorPlan() {
            const floor = document.getElementById('floor-plan');
            floor.innerHTML = '';
            // RÉCUPÉRATION DEPUIS LA CLÉ UNIFIÉE
            const tables = JSON.parse(localStorage.getItem('EMPIRE_TABLES')) || [];
            const queue = JSON.parse(localStorage.getItem('EMPIRE_QUEUE')) || [];

            tables.forEach(t => {
                const div = document.createElement('div');
                div.className = 'table-obj';
                const hasOrder = queue.some(o => o.table === t.label || o.table === t.id);
                if(hasOrder) div.classList.add('occupied');
                
                div.innerHTML = t.label;
                div.style.left = t.l+'px'; div.style.top = t.t+'px';
                div.style.width = t.w+'px'; div.style.height = t.h+'px';
                
                // --- FIX : CAPTURE DU CLIC SANS FAILLE ---
                div.onpointerdown = (e) => {
                    e.stopPropagation();
                    openCaisse(t.label || t.id);
                };
                floor.appendChild(div);
            });
        }

        function openCaisse(label) {
            currentTableId = label;
            document.getElementById('table-title').innerText = "TABLE " + label;
            currentTicket = JSON.parse(localStorage.getItem('EMPIRE_TMP_ORDER_'+label)) || [];
            renderTicket();
            renderMenu();
            document.getElementById('caisse-drawer').classList.add('open');
        }

        function renderMenu() {
            const menu = JSON.parse(localStorage.getItem('empire_recipes')) || [{name:'Plat Test', price:25, category:'Plat'}];
            document.getElementById('menu-items').innerHTML = menu.map(m => `
                <div class="btn-item" onclick="addItem('${m.name.replace(/'/g, "\\'")}', ${m.price})">
                    ${m.name}<br><small style="color:var(--accent)">${m.price}€</small>
                </div>`).join('');
        }

        function addItem(n, p) {
            currentTicket.push({id: Date.now(), name: n, price: p});
            renderTicket();
            localStorage.setItem('EMPIRE_TMP_ORDER_'+currentTableId, JSON.stringify(currentTicket));
        }

        function renderTicket() {
            const list = document.getElementById('ticket-list');
            let total = 0;
            list.innerHTML = currentTicket.map((i, idx) => {
                total += i.price;
                return `<div style="display:flex; justify-content:space-between; padding:10px 0; border-bottom:1px solid #111;">
                    <span>1x ${i.name}</span>
                    <span>${i.price}€</span>
                </div>`;
            }).join('');
            document.getElementById('total-val').innerText = total.toFixed(2) + " €";
        }

        function sendOrder() {
            if(currentTicket.length === 0) return;
            const queue = JSON.parse(localStorage.getItem('EMPIRE_QUEUE')) || [];
            const obs = document.getElementById('order-observation').value;

            queue.push({
                id: 'ORD_' + Date.now(),
                table: currentTableId,
                time: new Date().toLocaleTimeString('fr-FR', {hour:'2-digit', minute:'2-digit'}),
                ticket: { entrees:[], plats:currentTicket, desserts:[], boissons:[] },
                observation: obs,
                status: 'pending'
            });

            localStorage.setItem('EMPIRE_QUEUE', JSON.stringify(queue));
            localStorage.removeItem('EMPIRE_TMP_ORDER_'+currentTableId);
            document.getElementById('order-observation').value = '';
            closeCaisse();
            loadFloorPlan();
            alert("COMMANDE ENVOYÉE !");
        }

        // ÉCOUTEUR DE SYNCHRO INTER-PAGES
        window.addEventListener('storage', () => {
            console.log("Données reçues du Gestionnaire");
            loadFloorPlan();
        });

        loadFloorPlan();
    </script>
</body>
</html>
