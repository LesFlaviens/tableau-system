<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Empire OS - Terminal Salle</title>
    <style>
        :root { --bg: #050505; --accent: #00e676; --alert: #ff1744; --text: #fff; --panel: #111; --blue: #00b0ff; --warning: #ffb300; }
        body { font-family: 'Inter', sans-serif; background: var(--bg); color: var(--text); margin: 0; display: flex; flex-direction: column; height: 100vh; overflow: hidden; }
        
        header { border-bottom: 2px solid #222; padding: 15px; background: #0a0a0a; display: flex; justify-content: space-between; align-items: center; z-index: 1000; }
        .header-title { color: var(--accent); font-weight: 900; text-transform: uppercase; letter-spacing: 2px; }

        .main-workspace { display: flex; flex: 1; position: relative; overflow: hidden; }
        
        /* PLAN DE SALLE : LE CLIC DOIT ÊTRE ROI */
        .floor-plan { flex: 1; position: relative; background: #050505; z-index: 10; overflow: auto; }
        
        .table-obj { 
            position: absolute; background: #1a1a1a; border: 3px solid #444; color: #fff; 
            display: flex; flex-direction: column; justify-content: center; align-items: center; 
            font-weight: 900; border-radius: 12px; cursor: pointer; 
            z-index: 5000; /* Priorité maximale sur tout le reste */
            box-shadow: 0 10px 20px rgba(0,0,0,0.5); font-size: 1.3rem;
            transition: transform 0.1s, border-color 0.2s;
            pointer-events: auto !important;
        }
        .table-obj:active { transform: scale(0.92); }
        .table-obj.occupied { border-color: var(--alert); color: var(--alert); background: rgba(255,0,0,0.05); }
        .table-obj.web-alert { border-color: var(--blue); animation: pulse-web 1.5s infinite; }
        @keyframes pulse-web { 0% { box-shadow: 0 0 0 0 rgba(0, 176, 255, 0.7); } 70% { box-shadow: 0 0 0 15px rgba(0, 176, 255, 0); } 100% { box-shadow: 0 0 0 0 rgba(0, 176, 255, 0); } }

        /* TIROIR RADAR (ESCAMPOTABLE) */
        #radar-drawer { position: absolute; top: 0; left: 0; width: 300px; height: 100%; background: #080808; border-right: 2px solid var(--blue); transform: translateX(-100%); transition: 0.3s; z-index: 8000; display: flex; flex-direction: column; }
        #radar-drawer.open { transform: translateX(0); }
        .btn-radar-trigger { position: absolute; bottom: 20px; left: 20px; z-index: 7000; background: var(--blue); color: #000; padding: 15px 25px; border-radius: 50px; font-weight: 900; cursor: pointer; }

        /* TIROIR CAISSE (DROITE) */
        .drawer-caisse { position: absolute; top: 0; right: 0; width: 100%; max-width: 480px; height: 100%; background: #0a0a0a; border-left: 3px solid #333; padding: 25px; z-index: 10000; transform: translateX(100%); transition: 0.3s; display: flex; flex-direction: column; box-sizing: border-box; }
        .drawer-caisse.open { transform: translateX(0); }

        .ticket-area { flex: 1; background: #000; border: 1px solid #222; border-radius: 10px; padding: 15px; overflow-y: auto; margin-bottom: 15px; font-family: monospace; font-size: 1.1rem; }
        .menu-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
        .btn-item { background: #161616; border: 1px solid #333; color: #fff; padding: 18px; border-radius: 8px; font-weight: bold; font-size: 1rem; text-align: left; }
        .btn-send { background: var(--accent); color: #000; padding: 22px; font-weight: 900; border: none; border-radius: 12px; font-size: 1.3rem; cursor: pointer; text-transform: uppercase; margin-top: 15px; }
    </style>
</head>
<body>

    <header>
        <div class="header-title">EMPIRE OS : TERMINAL DE SALLE</div>
        <div id="sync-status" style="font-size: 0.7rem; color: #555;">DÉCONNECTÉ</div>
        <button onclick="forceSync()" style="background:var(--warning); border:none; padding:5px 10px; border-radius:4px; font-weight:bold; cursor:pointer;">FORCE REFRESH</button>
    </header>

    <div class="main-workspace">
        <div class="floor-plan" id="floor-plan">
            </div>

        <div class="btn-radar-trigger" onclick="toggleRadar()">🌐 RADAR WEB</div>

        <div id="radar-drawer">
            <div style="padding:20px; border-bottom:1px solid #222; display:flex; justify-content:space-between; align-items:center;">
                <h3 style="margin:0; color:var(--blue);">WEB ORDERS</h3>
                <button onclick="toggleRadar()" style="color:#fff; background:none; border:none; font-size:1.5rem;">✕</button>
            </div>
            <div id="radar-list" style="padding:15px; overflow-y:auto;"></div>
        </div>

        <div id="caisse-drawer" class="drawer-caisse">
            <div style="display:flex; justify-content:space-between; margin-bottom:20px;">
                <h2 id="table-title" style="margin:0; color:var(--accent); font-size:2.2rem;">TABLE</h2>
                <button onclick="closeCaisse()" style="background:#333; border:none; color:#fff; width:50px; height:50px; border-radius:50%; font-size:1.5rem; cursor:pointer;">✕</button>
            </div>
            <div class="ticket-area" id="ticket-list"></div>
            <input type="text" id="order-obs" style="width:100%; background:#111; border:1px solid var(--warning); color:var(--warning); padding:15px; margin-bottom:15px; border-radius:8px; box-sizing:border-box;" placeholder="⚠️ OBSERVATIONS CLIENT...">
            <div class="menu-grid" id="menu-items"></div>
            <div id="total-val" style="font-size:2.5rem; font-weight:900; text-align:right; margin:20px 0; color:var(--accent);">0.00 €</div>
            <button class="btn-send" onclick="sendOrder()">🚀 ENVOYER EN PRODUCTION</button>
        </div>
    </div>

    <script>
        // --- 1. CONFIGURATION SYNCHRO SERVEUR ---
        const ws = new WebSocket((window.location.protocol === 'https:' ? 'wss://' : 'ws://') + window.location.host);
        let activeOrders = {};
        let currentTableId = null;
        let currentTicket = [];

        ws.onopen = () => { document.getElementById('sync-status').innerText = "SYNCHRONISÉ (LIVE)"; document.getElementById('sync-status').style.color = "var(--accent)"; };
        ws.onclose = () => { document.getElementById('sync-status').innerText = "ERREUR SYNC (RECONN...)"; document.getElementById('sync-status').style.color = "var(--alert)"; };

        ws.onmessage = (e) => {
            const msg = JSON.parse(e.data);
            if (msg.type === 'ORDER_UPDATE' || msg.type === 'PLAN_UPDATE') {
                activeOrders = msg.activeOrders || activeOrders;
                renderFloorPlan();
                renderRadar();
            }
        };

        // --- 2. MOTEUR DE SALLE ---
        function toggleRadar() { document.getElementById('radar-drawer').classList.toggle('open'); }
        function closeCaisse() { document.getElementById('caisse-drawer').classList.remove('open'); currentTableId = null; }

        async function forceSync() {
            // On va chercher le plan officiel sur le serveur
            const res = await fetch('/get-current-state');
            const data = await res.json();
            activeOrders = data.activeOrders;
            renderFloorPlan();
            renderRadar();
        }

        function renderFloorPlan() {
            const floor = document.getElementById('floor-plan');
            floor.innerHTML = '';
            
            // Le plan est désormais stocké au niveau global (Sync serveur)
            const tables = JSON.parse(localStorage.getItem('EMPIRE_TABLES')) || [];
            
            tables.forEach(t => {
                const div = document.createElement('div');
                div.className = 'table-obj';
                
                // État de la table
                const order = activeOrders[t.id] || activeOrders[t.label];
                if(order && order.status === 'pending') div.classList.add('occupied');
                if(t.id.includes('WEB')) div.classList.add('web-alert');

                div.innerHTML = `<span>${t.label}</span>`;
                div.style.left = t.l + 'px';
                div.style.top = t.t + 'px';
                div.style.width = t.w + 'px';
                div.style.height = t.h + 'px';

                // --- FIX FINAL DU CLIC TACTILE ---
                div.addEventListener('pointerdown', (e) => {
                    e.preventDefault();
                    e.stopPropagation();
                    openCaisse(t.label || t.id);
                });

                floor.appendChild(div);
            });
        }

        function openCaisse(label) {
            currentTableId = label;
            document.getElementById('table-title').innerText = label;
            currentTicket = activeOrders[label]?.items || [];
            renderTicket();
            renderMenu();
            document.getElementById('caisse-drawer').classList.add('open');
        }

        function renderMenu() {
            const menu = JSON.parse(localStorage.getItem('empire_recipes')) || [{name:'Test', price:20, category:'Plat'}];
            document.getElementById('menu-items').innerHTML = menu.map(m => `
                <div class="btn-item" onclick="addItem('${m.name.replace(/'/g, "\\'")}', ${m.price})">
                    ${m.name}<br><small style="color:var(--blue)">${m.price}€</small>
                </div>`).join('');
        }

        function addItem(n, p) {
            currentTicket.push({id: Date.now(), n: n, p: p, done: false});
            renderTicket();
        }

        function renderTicket() {
            const list = document.getElementById('ticket-list');
            let total = 0;
            list.innerHTML = currentTicket.map((i, idx) => {
                total += i.p || 0;
                return `<div style="display:flex; justify-content:space-between; padding:10px 0; border-bottom:1px solid #111;">
                    <span>1x ${i.n}</span><span>${(i.p || 0).toFixed(2)}€</span>
                </div>`;
            }).join('');
            document.getElementById('total-val').innerText = total.toFixed(2) + " €";
        }

        async function sendOrder() {
            if(currentTicket.length === 0) return;
            const obs = document.getElementById('order-obs').value;
            
            const order = {
                table: currentTableId,
                items: currentTicket,
                observation: obs,
                time: new Date().toLocaleTimeString('fr-FR', {hour:'2-digit', minute:'2-digit'}),
                status: 'pending'
            };

            await fetch('/update-order', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ tableId: currentTableId, order })
            });

            document.getElementById('order-obs').value = '';
            closeCaisse();
            alert("ENVOYÉ !");
        }

        function renderRadar() {
            const container = document.getElementById('radar-list');
            const web = Object.values(activeOrders).filter(o => o.table?.toString().startsWith('WEB'));
            container.innerHTML = web.map(o => `
                <div style="background:#111; padding:15px; border-radius:8px; margin-bottom:10px; border-left:4px solid var(--blue);">
                    <b>${o.table}</b> - ${o.time}
                </div>`).join('');
        }

        forceSync();
        renderFloorPlan();
    </script>
</body>
</html>
