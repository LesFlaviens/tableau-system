            queue.push({ id: 'ORD_' + Date.now(), table: currentTableId, time: new Date().toLocaleTimeString('fr-FR', {hour:'2-digit', minute:'2-digit'}), ticket: ticketStruct, observation: obs, status: 'pending' });
            localStorage.setItem('empire_kds_queue', JSON.stringify(queue));
            localStorage.removeItem('empire_order_'+currentTableId);
            document.getElementById('order-observation').value = '';
            alert("Bon envoyé !");
            closeCaisse();
            loadZones();
        }

        window.addEventListener('storage', () => { renderWebRadar(); loadZones(); });
        renderWebRadar(); loadZones();
    </script>
</body>
</html>
