    <style>
        :root { --bg: #050505; --accent: #00e676; --alert: #ff1744; --text: #fff; --panel: #111; --blue: #00b0ff; --warning: #ffb300; }
        body { font-family: 'Inter', sans-serif; background: var(--bg); color: var(--text); margin: 0; display: flex; flex-direction: column; height: 100vh; overflow: hidden; touch-action: manipulation; }
        
        header { border-bottom: 1px solid #333; padding: 10px 20px; background: #0a0a0a; display: flex; justify-content: space-between; align-items: center; }
        .header-title { color: var(--accent); font-size: 1.2rem; font-weight: 900; text-transform: uppercase; }

        /* NAVIGATION ZONES */
        .zones-bar { display: flex; background: #000; border-bottom: 1px solid #222; overflow-x: auto; }
        .zone-tab { padding: 15px 25px; font-weight: 900; text-transform: uppercase; cursor: pointer; color: #555; border-right: 1px solid #222; }
        .zone-tab.active { background: var(--accent); color: #000; }
        @keyframes tab-alert { 0%, 100% { background: transparent; } 50% { background: var(--alert); color: #fff; } }
        .zone-tab.has-order { animation: tab-alert 1.5s infinite; }

        .main-workspace { display: flex; flex: 1; overflow: hidden; position: relative; }

        /* RADAR TIROIR */
        #radar-drawer { position: absolute; top: 0; left: 0; width: 320px; height: 100%; background: #0a0a0a; border-right: 2px solid var(--blue); transform: translateX(-100%); transition: 0.3s; z-index: 10000; display: flex; flex-direction: column; }
        #radar-drawer.open { transform: translateX(0); }
        .btn-radar-float { position: absolute; bottom: 20px; left: 20px; z-index: 9000; background: var(--blue); color: #000; padding: 15px 25px; border-radius: 50px; font-weight: 900; cursor: pointer; box-shadow: 0 5px 20px rgba(0,0,0,0.5); }

        /* PLAN DE SALLE */
        .floor-plan { flex: 1; position: relative; background: #050505; overflow: hidden; }
        .table-obj { position: absolute; background: #161616; border: 2px solid #555; color: #fff; display: flex; justify-content: center; align-items: center; font-weight: 900; border-radius: 12px; cursor: pointer; font-size: 1.2rem; z-index: 50; }
        .table-obj.occupied { border-color: var(--alert); color: var(--alert); }

        /* TIROIR COMMANDE */
        .drawer-caisse { position: absolute; top: 0; right: 0; width: 100%; max-width: 480px; height: 100%; background: #0a0a0a; border-left: 2px solid #333; padding: 25px; z-index: 11000; transform: translateX(100%); transition: 0.3s; display: flex; flex-direction: column; box-sizing: border-box; }
        .drawer-caisse.open { transform: translateX(0); }

        .ticket-area { flex: 1; background: #000; border: 1px solid #222; border-radius: 10px; padding: 15px; overflow-y: auto; margin-bottom: 15px; font-family: monospace; }
        .obs-input { width: 100%; background: #111; border: 1px solid var(--warning); border-radius: 8px; color: var(--warning); padding: 15px; margin-bottom: 15px; font-weight: bold; box-sizing: border-box; }
        
        .menu-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
        .btn-item { background: #1a1a1a; border: 1px solid #333; color: #fff; padding: 15px; border-radius: 8px; cursor: pointer; text-align: left; }
        .btn-send { background: var(--accent); color: #000; padding: 20px; font-weight: 900; border: none; border-radius: 10px; cursor: pointer; text-transform: uppercase; width: 100%; font-size: 1.2rem; margin-top: 10px; }
        
        .cat-tabs { display: flex; gap: 8px; margin-bottom: 15px; overflow-x: auto; }
        .cat-tab { padding: 10px 15px; background: #111; border: 1px solid #333; border-radius: 20px; font-size: 0.7rem; color: #888; font-weight: 900; cursor: pointer; text-transform: uppercase; white-space: nowrap; }
        .cat-tab.active { background: var(--blue); color: #000; border-color: var(--blue); }
    </style>
</head>
<body>

    <header>
        <div class="header-title">EMPIRE TERMINAL</div>
        <button onclick="localStorage.clear(); location.reload();" style="background:var(--alert); color:#fff; border:none; padding:5px 10px; border-radius:4px; font-size:0.6rem; cursor:pointer;">PURGER CACHE</button>
    </header>

    <div class="zones-bar" id="zones-tabs"></div>

    <div class="main-workspace">
        <div class="btn-radar-float" onclick="toggleRadar()">🌐 RADAR <span id="radar-badge" style="display:none; background:#000; color:#fff; padding:0 5px; border-radius:10px;">0</span></div>

        <div id="radar-drawer">
            <div style="padding:20px; border-bottom:1px solid #222; display:flex; justify-content:space-between; align-items:center;">
                <h3 style="margin:0; color:var(--blue);">WEB ORDERS</h3>
                <button onclick="toggleRadar()" style="color:#fff; background:none; border:none; font-size:1.5rem;">✕</button>
            </div>
            <div id="radar-list" style="padding:15px; overflow-y:auto;"></div>
        </div>

        <div class="floor-plan" id="floor-plan"></div>

        <div id="caisse-drawer" class="drawer-caisse">
            <div style="display:flex; justify-content:space-between; margin-bottom:20px;">
                <h2 id="table-title" style="margin:0; color:var(--accent);">TABLE</h2>
                <button onclick="closeCaisse()" style="background:#333; border:none; color:#fff; width:45px; height:45px; border-radius:50%; font-size:1.5rem;">✕</button>
            </div>
            <div class="ticket-area" id="ticket-list"></div>
            <input type="text" id="order-observation" class="obs-input" placeholder="⚠️ OBSERVATIONS (Allergies, sans...)">
            <div class="cat-tabs" id="cat-tabs"></div>
            <div class="menu-grid" id="menu-items"></div>
            <div id="total-val" style="font-size:2rem; font-weight:900; text-align:right; margin:15px 0; color:var(--accent);">0.00 €</div>
            <button class="btn-send" onclick="sendOrder()">🔥 ENVOYER CUISINE</button>
        </div>
    </div>

    <script>
        let currentZoneId = 'z1';
        let currentTableId = null;
        let currentTicket = [];

        function toggleRadar() { document.getElementById('radar-drawer').classList.toggle('open'); }
        function closeCaisse() { document.getElementById('caisse-drawer').classList.remove('open'); currentTableId = null; }

        function renderWebRadar() {
            const queue = JSON.parse(localStorage.getItem('empire_kds_queue')) || [];
            const web = queue.filter(o => o.id && o.id.toString().startsWith('WEB_'));
            document.getElementById('radar-badge').style.display = web.length > 0 ? 'inline' : 'none';
            document.getElementById('radar-badge').innerText = web.length;
            document.getElementById('radar-list').innerHTML = web.map(o => `
                <div style="background:#111; padding:12px; border-radius:8px; margin-bottom:10px; border-left:4px solid var(--blue);">
                    <b>${o.table}</b><br><small>${o.time}</small>
                </div>`).join('');
        }

        function loadZones() {
            const zones = JSON.parse(localStorage.getItem('empire_salle_zones')) || [{id:'z1', name:'RESTAURANT'}, {id:'z2', name:'TERRASSE'}];
            const queue = JSON.parse(localStorage.getItem('empire_kds_queue')) || [];
            const tables = JSON.parse(localStorage.getItem('empire_salle_tables')) || [];
            const activeZones = new Set();
            queue.forEach(o => { const t = tables.find(tbl => tbl.label === o.table || tbl.id === o.table); if(t) activeZones.add(t.zoneId); });

            document.getElementById('zones-tabs').innerHTML = zones.map(z => `
                <div class="zone-tab ${z.id === currentZoneId ? 'active' : ''} ${activeZones.has(z.id) ? 'has-order' : ''}" 
                     onclick="currentZoneId='${z.id}'; loadZones();">${z.name}</div>`).join('');
            loadFloorPlan();
        }

        function loadFloorPlan() {
            const floor = document.getElementById('floor-plan');
            floor.innerHTML = '';
            const tables = JSON.parse(localStorage.getItem('empire_salle_tables')) || [
                {id:'T1', l:50, t:50, w:100, h:100, label:'T1', zoneId:'z1'},
                {id:'T2', l:200, t:50, w:100, h:100, label:'T2', zoneId:'z1'}
            ];
            const queue = JSON.parse(localStorage.getItem('empire_kds_queue')) || [];

            tables.filter(t => t.zoneId === currentZoneId).forEach(t => {
                const div = document.createElement('div');
                div.className = 'table-obj' + (queue.some(o => o.table === t.label) ? ' occupied' : '');
                div.innerHTML = t.label;
                div.style.left = t.l+'px'; div.style.top = t.t+'px';
                div.style.width = t.w+'px'; div.style.height = t.h+'px';
                
                // FORCE CLICK
                div.addEventListener('click', (e) => {
                    e.preventDefault();
                    openCaisse(t.label || t.id);
                });
                floor.appendChild(div);
            });
        }

        function openCaisse(label) {
            currentTableId = label;
            document.getElementById('table-title').innerText = "TABLE " + label;
            currentTicket = JSON.parse(localStorage.getItem('empire_order_'+label)) || [];
            renderTicket();
            renderMenu('Plat');
            document.getElementById('caisse-drawer').classList.add('open');
        }

        function renderMenu(cat) {
            const menu = JSON.parse(localStorage.getItem('empire_recipes')) || [{name:'Plat Test', price:20, category:'Plat'}];
            const cats = ['Entrée', 'Plat', 'Dessert', 'Boisson'];
            document.getElementById('cat-tabs').innerHTML = cats.map(c => `<div class="cat-tab ${c===cat?'active':''}" onclick="renderMenu('${c}')">${c}</div>`).join('');
            document.getElementById('menu-items').innerHTML = menu.filter(m => m.category === cat).map(m => `
                <div class="btn-item" onclick="addItem('${m.name}', ${m.price}, '${m.category}')"><b>${m.name}</b><br>${m.price}€</div>`).join('');
        }

        function addItem(n, p, c) {
            currentTicket.push({id: Date.now(), name: n, price: p, category: c});
            renderTicket();
            localStorage.setItem('empire_order_'+currentTableId, JSON.stringify(currentTicket));
        }

        function renderTicket() {
            const list = document.getElementById('ticket-list');
            let total = 0;
            list.innerHTML = currentTicket.map((i, idx) => { 
                total += i.price; 
                return `<div style="display:flex; justify-content:space-between; margin-bottom:5px;">
                    <span onclick="removeItem(${idx})" style="color:red; margin-right:10px;">✕</span>
                    <span>1x ${i.name}</span><span>${i.price}€</span></div>`; 
            }).join('');
            document.getElementById('total-val').innerText = total.toFixed(2) + " €";
        }

        function removeItem(idx) {
            currentTicket.splice(idx, 1);
            renderTicket();
            localStorage.setItem('empire_order_'+currentTableId, JSON.stringify(currentTicket));
        }

        function sendOrder() {
            if(currentTicket.length === 0) return;
            const obs = document.getElementById('order-observation').value.trim();
            const queue = JSON.parse(localStorage.getItem('empire_kds_queue')) || [];
            const ticketStruct = { entrees:[], plats:[], desserts:[], boissons:[] };
            currentTicket.forEach(i => {
                if(i.category === 'Entrée') ticketStruct.entrees.push(i);
                else if(i.category === 'Plat') ticketStruct.plats.push(i);
                else if(i.category === 'Dessert') ticketStruct.desserts.push(i);
                else ticketStruct.boissons.push(i);
            });
            queue.push({ id: 'ORD_' + Date.now(), table: currentTableId, time: new Date().toLocaleTimeString('fr-FR', {hour:'2-digit', minute:'2-digit'}), ticket: ticketStruct, observation: obs, status: 'pending' });
            localStorage.setItem('empire_kds_queue', JSON.stringify(queue));
            localStorage.removeItem('empire_order_'+currentTableId);
            document.getElementById('order-observation').value = '';
            alert("Bon envoyé !");
            closeCaisse();
            loadZones();
        }

        window.addEventListener('storage', () => { renderWebRadar(); loadZones(); });
        renderWebRadar(); loadZones();
    </script>
</body>
