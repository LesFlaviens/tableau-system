<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Empire OS - Tableau Général de Salle</title>
    <style>
        :root { --bg: #050505; --accent: #00e676; --alert: #ff1744; --text: #fff; --panel: #111; --blue: #00b0ff; --warning: #ffb300; --sub: #888; }
        body { font-family: 'Inter', sans-serif; background: var(--bg); color: var(--text); margin: 0; display: flex; flex-direction: column; height: 100vh; overflow: hidden; touch-action: manipulation; }
        
        header { border-bottom: 1px solid #333; padding: 15px 25px; background: #0a0a0a; display: flex; justify-content: space-between; align-items: center; flex-shrink: 0; }
        .header-title { color: var(--accent); font-size: 1.3rem; font-weight: 900; text-transform: uppercase; letter-spacing: 2px; }
        .btn-top { background: #111; border: 1px solid #333; color: #fff; padding: 10px 18px; border-radius: 8px; font-weight: bold; cursor: pointer; text-transform: uppercase; font-size: 0.75rem; }

        .main-workspace { display: flex; flex: 1; overflow: hidden; position: relative; }
        
        /* RADAR WOOCOMMERCE - SECTION GAUCHE */
        #radar-container { width: 320px; background: #080808; border-right: 1px solid #222; display: flex; flex-direction: column; z-index: 100; transition: 0.3s; }
        .radar-header { padding: 15px; border-bottom: 1px solid #222; display: flex; align-items: center; gap: 10px; color: var(--blue); }
        .radar-title { font-size: 0.8rem; font-weight: 900; text-transform: uppercase; letter-spacing: 1px; }
        .web-order-card { background: #111; border: 1px solid #333; border-left: 4px solid var(--blue); padding: 15px; border-radius: 8px; margin: 10px; animation: slideIn 0.3s ease-out; }
        @keyframes slideIn { from { opacity: 0; transform: translateX(-20px); } to { opacity: 1; transform: translateX(0); } }
        
        /* ALERTE VISUELLE COMMANDE WEB */
        @keyframes radar-pulse { 0% { box-shadow: inset 0 0 0 0 rgba(0, 176, 255, 0.4); } 50% { box-shadow: inset 0 0 20px 5px rgba(0, 176, 255, 0.2); } 100% { box-shadow: inset 0 0 0 0 rgba(0, 176, 255, 0); } }
        .radar-alert { animation: radar-pulse 1s infinite; }

        /* PLAN DE SALLE - SECTION CENTRALE */
        .floor-plan { flex: 1; position: relative; background: #050505; overflow: hidden; }
        .table-obj { position: absolute; background: #161616; border: 2px solid #555; color: #fff; display: flex; flex-direction: column; justify-content: center; align-items: center; font-weight: 900; border-radius: 12px; cursor: pointer; box-shadow: 0 5px 15px rgba(0,0,0,0.5); font-size: 1.2rem; transition: 0.2s; }
        .table-obj:active { transform: scale(0.95); }
        .table-obj.occupied { border-color: var(--alert); background: rgba(255, 23, 68, 0.05); }
        .pax-label { font-size: 0.75rem; color: var(--blue); margin-top: 5px; }
        .table-badge { position: absolute; top: -10px; right: -10px; background: var(--warning); color: #000; font-size: 0.7rem; padding: 4px 8px; border-radius: 12px; font-weight: 900; border: 2px solid #000; }

        /* TIROIR CAISSE - SECTION DROITE */
        .drawer { position: absolute; top: 0; right: 0; width: 100%; max-width: 480px; height: 100%; background: #0a0a0a; border-left: 2px solid #333; padding: 25px; z-index: 9000; box-sizing: border-box; transform: translateX(100%); transition: 0.3s cubic-bezier(0.4, 0, 0.2, 1); display: flex; flex-direction: column; }
        .drawer.open { transform: translateX(0); }
        
        .ticket-list { flex: 1; background: #000; border: 1px solid #222; border-radius: 10px; padding: 20px; overflow-y: auto; margin-bottom: 20px; }
        .ticket-item { display: flex; justify-content: space-between; border-bottom: 1px solid #111; padding: 10px 0; font-weight: bold; }
        
        .menu-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; }
        .btn-item { background: #161616; border: 1px solid #333; color: #fff; padding: 15px; border-radius: 8px; cursor: pointer; font-size: 0.9rem; text-align: left; transition: 0.1s; }
        .btn-item:active { background: #222; }
        
        .cat-tabs { display: flex; gap: 8px; margin-bottom: 15px; overflow-x: auto; padding-bottom: 5px; }
        .cat-tab { padding: 10px 20px; background: #1a1a1a; border: 1px solid #333; border-radius: 6px; font-size: 0.75rem; color: #888; font-weight: 900; cursor: pointer; text-transform: uppercase; white-space: nowrap; }
        .cat-tab.active { background: var(--accent); color: #000; border-color: var(--accent); }
        
        .btn-send { background: var(--blue); color: #000; padding: 20px; font-weight: 900; border: none; border-radius: 10px; cursor: pointer; text-transform: uppercase; width: 100%; font-size: 1.1rem; margin-top: 15px; box-shadow: 0 5px 15px rgba(0, 176, 255, 0.3); }

    </style>
</head>
<body>

    <header>
        <div class="header-title">TABLEAU DU SERVICE</div>
        <div style="display:flex; gap:12px;">
            <button class="btn-top" style="border-color:var(--purple); color:var(--purple);">📅 RÉSERVATIONS</button>
            <button class="btn-top" id="btn-chef" style="display:none; border-color:var(--warning); color:var(--warning);">🔐 ACCÈS CHEF</button>
        </div>
    </header>

    <div class="main-workspace">
        <div id="radar-container">
            <div class="radar-header">
                <span style="font-size:1.2rem;">🌐</span>
                <span class="radar-title">RADAR WOOCOMMERCE</span>
            </div>
            <div id="radar-list" style="flex:1; overflow-y:auto;">
                <div style="color:#333; text-align:center; margin-top:50px; font-style:italic;">En attente de commandes web...</div>
            </div>
        </div>

        <div class="floor-plan" id="floor-plan"></div>

        <div id="order-drawer" class="drawer">
            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:20px;">
                <h2 id="drawer-table-name" style="margin:0; color:var(--blue); font-size:1.8rem; text-transform:uppercase;">TABLE</h2>
                <button onclick="closeDrawer()" style="background:#222; border:none; color:#fff; width:45px; height:45px; border-radius:50%; font-size:1.5rem; cursor:pointer;">✕</button>
            </div>
            <div class="ticket-list" id="ticket-list"></div>
            <div class="cat-tabs" id="cat-tabs"></div>
            <div class="menu-grid" id="menu-items"></div>
            <div id="total-val" style="font-size:2.2rem; font-weight:900; text-align:right; margin:15px 0; color:var(--accent);">0.00 €</div>
            <button class="btn-send" onclick="sendOrder()">🔥 ENVOYER EN PRODUCTION</button>
        </div>
    </div>

    <script>
        const urlParams = new URLSearchParams(window.location.search);
        if(urlParams.get('key') === 'ICHEF2026') document.getElementById('btn-chef').style.display = 'block';

        let currentTableId = null;
        let currentTicket = [];

        // 1. GESTION DU RADAR WEB
        function renderWebRadar() {
            const queue = JSON.parse(localStorage.getItem('empire_kds_queue')) || [];
            const container = document.getElementById('radar-list');
            const webOrders = queue.filter(o => o.id && o.id.toString().startsWith('WEB_'));
            
            const radarBox = document.getElementById('radar-container');
            if(webOrders.length > 0) radarBox.classList.add('radar-alert');
            else radarBox.classList.remove('radar-alert');

            if(webOrders.length === 0) {
                container.innerHTML = '<div style="color:#333; text-align:center; margin-top:50px; font-style:italic;">En attente de commandes web...</div>';
                return;
            }

            container.innerHTML = webOrders.map(o => `
                <div class="web-order-card">
                    <div style="display:flex; justify-content:space-between; margin-bottom:5px;">
                        <b style="color:var(--blue); font-size:1.1rem;">${o.table}</b>
                        <span style="color:#555; font-size:0.75rem;">${o.time}</span>
                    </div>
                    <div style="color:#888; font-size:0.8rem;">ID: ${o.id}</div>
                </div>
            `).join('');
        }

        // 2. PLAN DE SALLE
        function loadFloorPlan() {
            const floor = document.getElementById('floor-plan');
            floor.innerHTML = '';
            const tables = JSON.parse(localStorage.getItem('empire_salle_tables')) || [
                {id:'T1', l:400, t:400, w:120, h:120, label:'T1'},
                {id:'T4', l:550, t:200, w:100, h:100, label:'T4'}
            ];

            tables.forEach(t => {
                const div = document.createElement('div');
                div.className = 'table-obj';
                const saved = JSON.parse(localStorage.getItem('empire_order_'+t.id)) || [];
                if(saved.length > 0) div.classList.add('occupied');
                
                div.innerHTML = `<span>${t.label}</span><span class="pax-label">1p</span>`;
                div.style.left = t.l+'px'; div.style.top = t.t+'px';
                div.style.width = t.w+'px'; div.style.height = t.h+'px';
                
                if(saved.length > 0) div.innerHTML += '<div class="table-badge">🍽️</div>';
                div.onclick = () => openOrder(t.id);
                floor.appendChild(div);
            });
        }

        // 3. MOTEUR DE COMMANDE
        function openOrder(id) {
            currentTableId = id;
            document.getElementById('drawer-table-name').innerText = "Table " + id;
            currentTicket = JSON.parse(localStorage.getItem('empire_order_'+id)) || [];
            renderTicket();
            renderMenu('Plat');
            document.getElementById('order-drawer').classList.add('open');
        }

        function closeDrawer() { document.getElementById('order-drawer').classList.remove('open'); }

        function renderMenu(cat) {
            const menu = JSON.parse(localStorage.getItem('empire_recipes')) || [
                {name:'Bavette', price:24, category:'Plat'},
                {name:'Salade César', price:14, category:'Entrée'},
                {name:'Mousse Choco', price:8, category:'Dessert'},
                {name:'Mojito', price:12, category:'Boisson'}
            ];
            const cats = ['Entrée', 'Plat', 'Dessert', 'Boisson'];
            document.getElementById('cat-tabs').innerHTML = cats.map(c => `
                <div class="cat-tab ${c === cat ? 'active' : ''}" onclick="renderMenu('${c}')">${c}s</div>
            `).join('');
            document.getElementById('menu-items').innerHTML = menu.filter(m => m.category === cat).map(m => `
                <div class="btn-item" onclick="addItem('${m.name}', ${m.price}, '${m.category}')">
                    <b>${m.name}</b><br><span style="color:var(--blue);">${m.price.toFixed(2)}€</span>
                </div>
            `).join('');
        }

        function addItem(n, p, c) {
            currentTicket.push({id: Date.now(), name: n, price: p, category: c});
            renderTicket();
            localStorage.setItem('empire_order_'+currentTableId, JSON.stringify(currentTicket));
            loadFloorPlan();
        }

        function renderTicket() {
            const list = document.getElementById('ticket-list');
            let total = 0;
            list.innerHTML = currentTicket.map((i, index) => {
                total += i.price;
                return `<div class="ticket-item">
                    <span>1x ${i.name}</span>
                    <span>${i.price.toFixed(2)}€</span>
                </div>`;
            }).join('');
            document.getElementById('total-val').innerText = total.toFixed(2) + " €";
        }

        function sendOrder() {
            if(currentTicket.length === 0) return;
            const queue = JSON.parse(localStorage.getItem('empire_kds_queue')) || [];
            const ticketStruct = { entrees:[], plats:[], desserts:[], boissons:[] };
            currentTicket.forEach(i => {
                if(i.category === 'Entrée') ticketStruct.entrees.push(i);
                else if(i.category === 'Plat') ticketStruct.plats.push(i);
                else if(i.category === 'Dessert') ticketStruct.desserts.push(i);
                else ticketStruct.boissons.push(i);
            });
            queue.push({
                id: 'ORD_' + Date.now(),
                table: currentTableId,
                time: new Date().toLocaleTimeString('fr-FR', {hour:'2-digit', minute:'2-digit'}),
                ticket: ticketStruct,
                status: 'pending'
            });
            localStorage.setItem('empire_kds_queue', JSON.stringify(queue));
            alert("Envoyé en Cuisine & Bar !");
            closeDrawer();
        }

        window.addEventListener('storage', () => { renderWebRadar(); loadFloorPlan(); });
        renderWebRadar(); loadFloorPlan();
    </script>
</body>
</html>
