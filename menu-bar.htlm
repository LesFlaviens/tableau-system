<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Menu Premium - Bar</title>
    <style>
        /* 🟢 PALETTE LUXURY DARK MODE */
        :root { 
            --bg-deep: #050505;
            --panel-bg: #111111;
            --border: #222222;
            --text-main: #f8fafc;    
            --text-muted: #888888;   
            --gold: #fbbf24;         
            --gold-dim: rgba(251, 191, 36, 0.1);
            --accent: #10b981; 
            --alert: #ef4444;        
        }
        
        body { 
            font-family: 'Helvetica Neue', 'Inter', sans-serif; 
            background: var(--bg-deep); 
            color: var(--text-main); 
            margin: 0; 
            display: flex; 
            flex-direction: column; 
            height: 100vh; 
            overflow: hidden; 
            -webkit-font-smoothing: antialiased;
        }
        
        /* HEADER LUXE */
        header { 
            background: var(--bg-deep); 
            padding: 20px; 
            text-align: center; 
            border-bottom: 1px solid var(--border); 
            z-index: 100; 
            position: relative;
        }
        .logo-text { 
            color: var(--gold); 
            font-size: 2rem; 
            font-weight: 900; 
            letter-spacing: 5px; 
            margin: 0; 
            text-transform: uppercase; 
        }
        .tagline { 
            color: var(--text-muted); 
            font-size: 0.8rem; 
            letter-spacing: 3px; 
            text-transform: uppercase; 
            margin-top: 5px; 
        }
        
        /* LIVE INDICATOR */
        .live-badge {
            position: absolute;
            top: 25px;
            right: 20px;
            display: flex;
            align-items: center;
            gap: 6px;
            color: var(--text-muted);
            font-size: 0.65rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-weight: bold;
        }
        .live-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: var(--alert);
        }
        .live-dot.online {
            background: var(--accent);
            box-shadow: 0 0 8px var(--accent);
            animation: pulse-live 2s infinite;
        }
        @keyframes pulse-live { 0% { opacity: 1; } 50% { opacity: 0.5; } 100% { opacity: 1; } }

        /* NAVIGATION CATÉGORIES SCROLLABLE */
        .nav-categories { 
            display: flex; 
            overflow-x: auto; 
            background: #0a0a0a; 
            padding: 15px 20px; 
            gap: 15px; 
            border-bottom: 1px solid var(--border);
            scrollbar-width: none; /* Firefox */
        }
        .nav-categories::-webkit-scrollbar { display: none; } /* Safari and Chrome */
        
        .cat-btn { 
            background: transparent; 
            border: 1px solid var(--border); 
            color: var(--text-muted); 
            padding: 10px 20px; 
            border-radius: 30px; 
            font-size: 0.9rem; 
            font-weight: bold; 
            white-space: nowrap; 
            cursor: pointer; 
            transition: 0.3s; 
            text-transform: uppercase;
            letter-spacing: 1px;
        }
        .cat-btn.active { 
            background: var(--gold); 
            color: #000; 
            border-color: var(--gold); 
            box-shadow: 0 0 15px rgba(251, 191, 36, 0.3);
        }
        
        /* CONTENU DU MENU */
        .menu-content { 
            flex: 1; 
            overflow-y: auto; 
            padding: 30px 20px; 
            background: radial-gradient(circle at center, #111 0%, #050505 100%);
        }
        .menu-container {
            max-width: 800px;
            margin: 0 auto;
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        /* DESIGN DES ARTICLES */
        .menu-item { 
            display: flex; 
            align-items: center; 
            justify-content: space-between; 
            padding: 15px 0;
            border-bottom: 1px dashed #333;
            transition: 0.3s;
        }
        .item-info {
            display: flex;
            flex-direction: column;
            flex: 1;
            padding-right: 20px;
        }
        .item-name { 
            font-size: 1.2rem; 
            font-weight: 700; 
            color: var(--text-main); 
            letter-spacing: 1px;
        }
        .item-price { 
            font-size: 1.2rem; 
            font-weight: 900; 
            color: var(--gold); 
            white-space: nowrap;
        }
        
        /* STATUT ÉPUISÉ */
        .menu-item.sold-out { 
            opacity: 0.4; 
        }
        .menu-item.sold-out .item-name { 
            text-decoration: line-through; 
        }
        .menu-item.sold-out .item-price { 
            color: var(--alert); 
            font-size: 1rem;
        }
        
        .empty-state {
            text-align: center;
            color: var(--text-muted);
            padding: 50px 20px;
            font-style: italic;
            font-size: 1.1rem;
        }

        /* Responsive Mobile */
        @media (max-width: 600px) {
            .logo-text { font-size: 1.5rem; }
            .cat-btn { padding: 8px 15px; font-size: 0.8rem; }
            .item-name { font-size: 1.1rem; }
            .item-price { font-size: 1.1rem; }
            .live-badge { display: none; } /* On cache sur les petits écrans pour épurer */
        }
    </style>
</head>
<body>

    <header>
        <h1 class="logo-text">ibar.ch</h1>
        <div class="tagline">La Carte</div>
        <div class="live-badge">
            <div id="sync-dot" class="live-dot"></div> <span id="sync-text">Hors Ligne</span>
        </div>
    </header>

    <div class="nav-categories" id="category-nav">
        </div>

    <div class="menu-content">
        <div class="menu-container" id="menu-display">
            <div class="empty-state">Chargement de la carte en cours...</div>
        </div>
    </div>

    <script>
        // -----------------------------------------
        // 1. MOTEUR DE SYNCHRONISATION (Lecture Seule)
        // -----------------------------------------
        const API = {
            getState: async () => {
                try {
                    if (window.location.protocol !== 'file:') {
                        let r = await fetch('/get-current-state');
                        if(r.ok) return await r.json();
                    } else throw new Error("Local");
                } catch(e) {
                    return JSON.parse(localStorage.getItem('EMPIRE_GLOBAL_SYNC')) || { activeOrders: {} };
                }
            }
        };

        // Rafraîchissement instantané si la base de données locale change
        window.addEventListener('storage', (e) => {
            if (e.key === 'EMPIRE_GLOBAL_SYNC') {
                fetchMenuData();
            }
        });

        // -----------------------------------------
        // 2. DONNÉES & CATÉGORIES
        // -----------------------------------------
        let barMenuData = { cocktails: [], mocktails: [], vins: [], bieres: [], chaudes: [], froides: [], spiritueux: [] };
        let activeCategory = 'cocktails';

        const CAT_NAMES = {
            "cocktails": "🍸 Cocktails",
            "mocktails": "🍹 Sans Alcool",
            "vins": "🍷 Vins",
            "bieres": "🍺 Bières",
            "chaudes": "☕ Chaudes",
            "froides": "🥤 Froides",
            "spiritueux": "🥃 Spiritueux"
        };
        const CAT_KEYS = Object.keys(CAT_NAMES);

        // -----------------------------------------
        // 3. AFFICHAGE
        // -----------------------------------------
        function buildNavigation() {
            const nav = document.getElementById('category-nav');
            nav.innerHTML = CAT_KEYS.map(cat => `
                <button class="cat-btn ${cat === activeCategory ? 'active' : ''}" onclick="switchCategory('${cat}')">
                    ${CAT_NAMES[cat]}
                </button>
            `).join('');
        }

        function switchCategory(cat) {
            activeCategory = cat;
            buildNavigation();
            renderMenu();
            
            // Auto-scroll pour centrer le bouton cliqué (UX Mobile)
            const activeBtn = document.querySelector('.cat-btn.active');
            if(activeBtn) {
                activeBtn.scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
            }
        }

        function renderMenu() {
            const display = document.getElementById('menu-display');
            const items = barMenuData[activeCategory] || [];

            if (items.length === 0) {
                display.innerHTML = `<div class="empty-state">Aucune boisson disponible dans cette catégorie pour le moment.</div>`;
                return;
            }

            // Trier pour mettre les articles "Épuisés" à la fin
            let sortedItems = [...items].sort((a, b) => {
                let aSoldOut = (a.stock === 0) ? 1 : 0;
                let bSoldOut = (b.stock === 0) ? 1 : 0;
                return aSoldOut - bSoldOut;
            });

            display.innerHTML = sortedItems.map(item => {
                let isSoldOut = (item.stock === 0);
                let priceDisplay = isSoldOut ? 'ÉPUISÉ' : `${parseFloat(item.price).toFixed(2)} €`;
                
                return `
                <div class="menu-item ${isSoldOut ? 'sold-out' : ''}">
                    <div class="item-info">
                        <div class="item-name">${item.name}</div>
                    </div>
                    <div class="item-price">${priceDisplay}</div>
                </div>`;
            }).join('');
        }

        // -----------------------------------------
        // 4. CONNEXION H24
        // -----------------------------------------
        async function fetchMenuData() {
            try {
                const state = await API.getState();
                const dot = document.getElementById('sync-dot');
                const text = document.getElementById('sync-text');

                if (state && state.activeOrders && state.activeOrders['MENU_MASTER_BAR']) {
                    barMenuData = state.activeOrders['MENU_MASTER_BAR'].data;
                    
                    dot.classList.add('online');
                    text.innerText = "En Direct";
                    
                    renderMenu();
                } else {
                    // Si le menu n'a jamais été créé par le bar
                    dot.classList.add('online');
                    text.innerText = "En Direct";
                }
            } catch (e) {
                document.getElementById('sync-dot').classList.remove('online');
                document.getElementById('sync-text').innerText = "Hors Ligne";
            }
        }

        // -----------------------------------------
        // 5. INITIALISATION
        // -----------------------------------------
        function bootSystem() {
            buildNavigation();
            fetchMenuData();
            // Rafraîchissement automatique toutes les 5 secondes pour les clients
            setInterval(fetchMenuData, 5000); 
        }

        bootSystem();
    </script>
</body>
</html>
